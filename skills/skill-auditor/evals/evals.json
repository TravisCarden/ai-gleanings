{
  "skill_name": "skill-auditor",
  "evals": [
    {
      "id": 1,
      "name": "basic_skill_audit",
      "prompt": "Review this skill using marketplace heuristics",
      "assertions": [
        {
          "name": "covers_structure",
          "description": "Output covers structure analysis"
        },
        {
          "name": "covers_token_footprint",
          "description": "Output reports token footprint"
        },
        {
          "name": "covers_routing_integrity",
          "description": "Output checks routing integrity (orphans, dangling links)"
        },
        {
          "name": "covers_frontmatter",
          "description": "Output validates frontmatter"
        },
        {
          "name": "covers_evals",
          "description": "Output checks for evals presence"
        }
      ]
    },
    {
      "id": 2,
      "name": "skill_improvement_request",
      "prompt": "Check the skill quality and suggest improvements",
      "assertions": [
        {
          "name": "runs_automated_checks",
          "description": "Output references automated checks phase"
        },
        {
          "name": "runs_manual_review",
          "description": "Output references manual review phase"
        },
        {
          "name": "evaluates_progressive_disclosure",
          "description": "Output evaluates progressive disclosure"
        },
        {
          "name": "evaluates_content_quality",
          "description": "Output evaluates content quality"
        }
      ]
    },
    {
      "id": 3,
      "name": "pre_release_review",
      "prompt": "Audit skill for pre-release review",
      "assertions": [
        {
          "name": "invokes_review_script",
          "description": "Output invokes or references `review-skill.sh`"
        },
        {
          "name": "reports_release_readiness",
          "description": "Output reports release readiness"
        },
        {
          "name": "categorizes_findings_by_severity",
          "description": "Findings are categorized by severity"
        }
      ]
    },
    {
      "id": 4,
      "name": "skill_structure_analysis",
      "prompt": "Analyze the skill structure and routing",
      "assertions": [
        {
          "name": "phase_1_automated_checks",
          "description": "Output covers Phase 1: Automated Checks"
        },
        {
          "name": "phase_2_manual_review",
          "description": "Output covers Phase 2: Manual Review"
        },
        {
          "name": "phase_3_reporting",
          "description": "Output covers Phase 3: Reporting"
        }
      ]
    },
    {
      "id": 5,
      "name": "token_optimization",
      "prompt": "Check for token bloat and optimization opportunities",
      "assertions": [
        {
          "name": "reports_token_footprint",
          "description": "Output reports token footprint with concrete numbers"
        },
        {
          "name": "applies_heuristic_flags",
          "description": "Output applies heuristic flags for size concerns"
        },
        {
          "name": "evaluates_progressive_disclosure",
          "description": "Output considers progressive disclosure as an optimization lever"
        }
      ]
    },
    {
      "id": 6,
      "name": "quality_standards",
      "prompt": "What quality standards does this skill enforce?",
      "assertions": [
        {
          "name": "hallucination_risk",
          "description": "Output mentions hallucination risk as a quality dimension"
        },
        {
          "name": "agent_ergonomics",
          "description": "Output mentions agent ergonomics"
        },
        {
          "name": "description_triggering",
          "description": "Output covers description triggering"
        },
        {
          "name": "redundancy",
          "description": "Output covers redundancy detection"
        }
      ]
    },
    {
      "id": 7,
      "name": "review_process",
      "prompt": "How does the skill review process work?",
      "assertions": [
        {
          "name": "names_review_script",
          "description": "Output names `./scripts/review-skill.sh`"
        },
        {
          "name": "describes_automated_checks",
          "description": "Output describes the automated-checks phase"
        },
        {
          "name": "describes_manual_review",
          "description": "Output describes the manual-review phase"
        },
        {
          "name": "describes_reporting_template",
          "description": "Output describes the reporting template"
        }
      ]
    },
    {
      "id": 8,
      "name": "anti_patterns",
      "prompt": "What should I avoid when reviewing skills?",
      "assertions": [
        {
          "name": "warns_against_style_preferences",
          "description": "Output warns against flagging style preferences"
        },
        {
          "name": "warns_against_token_budget_absolutism",
          "description": "Output warns against treating token budgets as absolutes"
        },
        {
          "name": "warns_against_perfect_is_enemy_of_good",
          "description": "Output warns against perfect-is-enemy-of-good gating"
        }
      ]
    }
  ]
}
