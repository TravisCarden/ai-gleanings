# Exemplary .gitignore for AI tooling projects

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor files
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.idea/workspace.xml
.idea/tasks.xml
*~
*.swp
*.swo

# Logs and temporary files
*.log
.scratch/
tmp/
temp/

# Environment variables (keep templates)
.env
.env.local
!.env.example

# Dependencies
node_modules/
.npm
.yarn/
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
*.egg-info/

# RTK cache and working files
.rtk-cache/

# Skill development artifacts
*/eval-results/
*/test-output/
*-workspace/

# Keep settings.local.json out of version control
/.claude/settings.local.json
